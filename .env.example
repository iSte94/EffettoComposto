# Database (SQLite locale)
DATABASE_URL="file:./dev.db"

# JWT Secret per autenticazione (OBBLIGATORIO in produzione)
JWT_SECRET="cambia-questo-con-una-stringa-segreta-lunga-almeno-32-caratteri"

# Secret per endpoint cron Mutui Market (opzionale, protegge il trigger manuale)
CRON_SECRET="cambia-con-stringa-sicura"

# Chiave di cifratura per API key AI salvate lato server (OBBLIGATORIA se si usa "Ricorda su questo account")
# Deve essere una stringa base64 di 32 byte. Generala con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=""

# URL pubblico dell'app usato per webhook Telegram e deep link /start
APP_BASE_URL="http://localhost:3000"

# Ambiente
NODE_ENV="development"
