// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preferences        Preference?
  assets             AssetRecord[]
  savingsGoals       SavingsGoal[]
  budgetTransactions BudgetTransaction[]
  dividends          DividendRecord[]
  aiThreads          AssistantThread[]
  aiMemory           AssistantMemory[]
}

model Preference {
  id                       String   @id @default(uuid())
  propertyPrice            Float    @default(300000)
  downpayment              Float    @default(60000)
  purchaseTaxes            Float    @default(6000)
  notaryFees               Float    @default(3000)
  agencyFees               Float    @default(9000)
  netIncome                Float    @default(4000)
  person1Name              String   @default("Persona 1")
  person1Income            Float    @default(2000)
  person2Name              String   @default("Persona 2")
  person2Income            Float    @default(2000)
  expensesList             String   @default("[]") // JSON string of [{id, name, amount}]
  hasExistingLoan          Boolean  @default(false)
  knowsExistingInstallment Boolean  @default(true)
  existingInstallment      Float    @default(0)
  existingRemainingCapital Float    @default(15000)
  existingRate             Float    @default(6.5)
  existingYearsLeft        Float    @default(5)
  rate                     Float    @default(3.5)
  years                    Float    @default(30)
  expectedRent             Float    @default(1200)
  maintenanceTaxes         Float    @default(300)
  marketReturn             Float    @default(7)
  vacancyRate              Float    @default(5)
  rentInflation            Float    @default(1.5)
  extraMaintenance         Float    @default(10000)
  realEstateList           String   @default("[]") // JSON string of Real Estate Properties
  existingLoansList        String   @default("[]") // JSON string of Existing Loans (Auto, etc.)
  customStocksList         String   @default("[]") // JSON string of Stocks/ETFs {ticker, shares, lastPrice}
  acceptedPurchases        String   @default("[]") // JSON string of accepted purchase simulations
  careerProgression        String   @default("[]") // JSON string of career progression predictions
  salaryCalculationHistory String   @default("[]") // JSON string of gross-to-net salary simulations

  // FIRE Parameters
  birthYear                Int?
  retirementAge            Int?
  expectedMonthlyExpenses  Float?
  monthlySavings           Float    @default(1000)
  fireWithdrawalRate       Float    @default(3.25)
  fireExpectedReturn       Float    @default(6.0)
  fireVolatility           Float    @default(15.0)
  expectedPublicPension    Float    @default(0)
  publicPensionAge         Int      @default(67)
  applyTaxStamp            Boolean  @default(true)
  includeIlliquidInFire    Boolean  @default(false)
  separateEmergencyFund    Boolean  @default(false)

  // Fondo Pensione Complementare
  enablePensionOptimizer   Boolean  @default(false)
  grossIncome              Float    @default(35000)
  pensionContribution      Float    @default(5164)
  pensionFundAccessAge     Int      @default(62)    // Eta accesso RITA
  pensionFundExitTaxRate   Float    @default(15)    // 9-15% in base ad anzianita
  pensionExitMode          String   @default("hybrid") // "annuity" = 100% rendita, "hybrid" = 50/50
  employerContributionType String   @default("percent") // "percent" o "fixed"
  employerContributionValue Float   @default(1.5)    // % RAL o importo fisso annuo

  // Budget Tracker
  budgetCategoriesList  String @default("[]") // JSON: [{id,name,limit,color,icon,keywords:string[]}]
  budgetSettings        String @default("{}") // JSON: {currentMonth?, viewMode: "month"|"avg"|"all"}
  subscriptionsList     String @default("[]") // JSON: [{id,name,amount,frequency:"mensile"|"annuale"}]

  // AI Settings (chiave cifrata lato server solo se rememberKeys = true)
  aiRememberKeys Boolean @default(false)
  aiProvider     String? // "gemini" | "openrouter"
  aiModel        String?
  aiApiKeyEnc    String? // AES-256-GCM(base64) della API key

  // AI: testo libero "Parlami di te" iniettato in ogni system prompt
  aiUserProfile  String  @default("")

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AssetRecord {
  id                 String   @id @default(uuid())
  date               DateTime @default(now())
  
  // Real Estate
  realEstateValue    Float    @default(0)
  realEstateCosts    Float    @default(0) // Costo annuale mantenimento
  realEstateRent     Float    @default(0) // Rendita presunta/effettiva annuale
  realEstateList     String   @default("[]") // Lista dettagliata
  
  // Liquid Assets (Stocks, Bonds, ETFs)
  liquidStockValue   Float    @default(0)
  stocksSnapshotValue Float   @default(0) // Valore titoli al momento del salvataggio
  customStocksList   String   @default("[]") // Snapshot of custom stocks holding
  
  // Safe Haven (Oro, Orologi, Arte)
  safeHavens         Float    @default(0)
  
  // Emergency Fund (Liquidità in Conto)
  emergencyFund      Float    @default(0)

  // Pension Fund (TFR)
  pensionFund        Float    @default(0)
  
  // Crypto
  bitcoinAmount      Float    @default(0)
  bitcoinPrice       Float    @default(0) // Snapshot del prezzo in EUR al momento del salvataggio
  
  // Passività (Mutui, Prestiti, Carte)
  debtsTotal         Float    @default(0)

  // Per-person ownership breakdown (JSON: {safeHavensP1, safeHavensP2, pensionFundP1, pensionFundP2, bitcoinAmountP1, bitcoinAmountP2})
  otherAssetsOwnership String  @default("{}")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model SavingsGoal {
  id           String   @id @default(uuid())
  name         String
  targetAmount Float
  currentAmount Float   @default(0)
  deadline     String?  // YYYY-MM format
  category     String   @default("general") // general, emergency, house, investment, travel, other
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StockHistoryCache {
  ticker    String   @id
  history   String   // JSON string of the [{timestamp, date, price, originalCurrency}] array
  updatedAt DateTime @updatedAt
}

model BudgetTransaction {
  id               String   @id @default(uuid())
  date             String   // YYYY-MM-DD
  description      String
  amount           Float    // negativo = uscita, positivo = entrata
  category         String
  categoryOverride Boolean  @default(false)
  hash             String   // dedupe key
  importedAt       DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hash])
  @@index([userId, date])
}

model MortgageMarketCache {
  id        String   @id @default(uuid())
  tipoTasso String   // "F" (fisso) or "V" (variabile)
  durata    Int      // 15, 20, 30
  data      String   // JSON array of mortgage offers
  scrapedAt DateTime @default(now())

  @@unique([tipoTasso, durata])
  @@index([scrapedAt])
}

model AssistantThread {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String   @default("Nuova conversazione")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  AssistantMessage[]

  @@index([userId, updatedAt])
}

model AssistantMessage {
  id        String   @id @default(uuid())
  threadId  String
  thread    AssistantThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  role      String   // "user" | "assistant"
  content   String   // testo messaggio
  toolTrace String?  // JSON AiToolTraceEntry[] (solo per assistant)
  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
}

model AssistantMemory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  category  String   // "profilo" | "obiettivo" | "decisione" | "preferenza" | "contesto"
  fact      String   // fatto sintetico (max ~300 char)
  pinned    Boolean  @default(false)
  source    String   @default("auto") // "auto" | "manual"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, category])
  @@index([userId, pinned])
}

model DividendRecord {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Asset reference (denormalized for query performance)
  assetTicker       String
  assetIsin         String?
  assetName         String?

  // Dates
  exDate            String   // YYYY-MM-DD
  paymentDate       String   // YYYY-MM-DD

  // Amounts
  dividendPerShare  Float    // In original currency
  quantity          Float    // Shares held at ex-date (for historical accuracy)
  grossAmount       Float    // Total gross = dps * quantity
  taxAmount         Float    @default(0)   // Withholding tax (26% IT default)
  netAmount         Float    // gross - tax

  // Currency handling
  currency          String   @default("EUR")
  grossAmountEur    Float?
  netAmountEur      Float?
  exchangeRate      Float?

  // Classification
  dividendType      String   @default("ordinary") // ordinary | extraordinary | interim | final | coupon
  isAutoGenerated   Boolean  @default(false)      // true if scraped from Borsa Italiana

  // Cost basis snapshot (for YoC accuracy)
  costPerShare      Float?

  // Metadata
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId, paymentDate])
  @@index([userId, assetTicker])
  @@unique([userId, assetTicker, exDate, dividendType])
}
